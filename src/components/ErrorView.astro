---
import Layout from '../layouts/Layout.astro';
import Header from './Header.astro';
import Footer from './Footer.astro';

interface Props {
  code: string;
  status: string;
  reason: string;
}

const { code, status, reason } = Astro.props;
---

<Layout 
  title={`${code} ${status} - useUtils`} 
  description={`${code} ${status}: ${reason}`}
>
  <Header />

  <!-- Main Body Content -->
  <main class="flex-grow w-full max-w-xl mx-auto px-4 py-24 flex flex-col items-center justify-center text-center gap-6">
    <div class="font-mono text-7xl md:text-8xl font-bold tracking-tighter text-zinc-700/60 dark:text-zinc-600/50 select-none">
      {code}
    </div>
    <div class="flex flex-col gap-2">
      <h1 class="text-2xl font-bold tracking-tight text-zinc-50 font-sans">
        {status}
      </h1>
      <p class="text-zinc-400 text-sm max-w-md mx-auto leading-relaxed">
        {reason}
      </p>
    </div>

    <div class="mt-4">
      <a 
        href="/" 
        class="inline-flex items-center gap-2 px-5 py-2.5 bg-zinc-900 border border-border-hairline hover:border-accent-emerald/40 hover:bg-zinc-850 hover:text-zinc-50 rounded-lg text-sm text-zinc-300 font-medium transition-all"
      >
        <span>Return Home</span>
        <span>→</span>
      </a>
    </div>
  </main>

  <Footer />
</Layout>
