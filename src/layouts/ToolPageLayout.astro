---
import Layout from './Layout.astro';

interface Props {
  title: string;
  description: string;
  keywords?: string;
  noindex?: boolean;
  toolTitle: string;
  toolDescription: string;
  version?: string;
  tabs?: Array<{ label: string; href: string; active?: boolean }>;
  faqs?: Array<{ question: string; answer: string }>;
  showPrivacyBanner?: boolean;
  privacyText?: string;
}

const {
  title,
  description,
  keywords,
  noindex = false,
  toolTitle,
  toolDescription,
  version = "v1.0.0",
  tabs = [],
  faqs = [],
  showPrivacyBanner = true,
  privacyText = "Processed locally in browser. Zero server transmission."
} = Astro.props;

// Build the JSON-LD schemas for search engines
const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "SoftwareApplication",
      "name": toolTitle,
      "operatingSystem": "All",
      "applicationCategory": "DeveloperApplication",
      "offers": {
        "@type": "Offer",
        "price": "0",
        "priceCurrency": "USD"
      },
      "description": toolDescription
    },
    ...(faqs.length > 0 ? [{
      "@type": "FAQPage",
      "mainEntity": faqs.map(faq => ({
        "@type": "Question",
        "name": faq.question,
        "acceptedAnswer": {
          "@type": "Answer",
          "text": faq.answer.replace(/<[^>]*>/g, '') // strip HTML tag formatting for clean schema text
        }
      }))
    }] : [])
  ]
};
---

<Layout 
  title={title} 
  description={description} 
  keywords={keywords}
  noindex={noindex}
>
  <!-- Main Navigation Header -->
  <header class="w-full bg-canvas border-b border-border-hairline h-14 sticky top-0 z-50">
    <div class="max-w-7xl mx-auto h-full px-4 flex items-center justify-between">
      <!-- Left side: Brand -->
      <a href="/" class="flex items-center gap-2 group">
        <div class="w-6 h-6 rounded bg-accent-emerald flex items-center justify-center font-mono font-black text-black text-sm select-none">
          u
        </div>
        <span class="font-sans font-semibold text-zinc-50 tracking-tight group-hover:text-accent-emerald transition-colors">
          useUtils
        </span>
      </a>

      <!-- Right side: Version & Theme -->
      <div class="flex items-center gap-3">
        <button
          type="button"
          class="theme-toggle-btn p-2 rounded-lg bg-zinc-900 border border-border-hairline text-zinc-400 hover:text-zinc-50 hover:bg-zinc-850 transition-all cursor-pointer flex items-center justify-center"
          aria-label="Toggle dark/light theme"
        >
          <!-- Sun Icon (visible in dark mode) -->
          <svg class="theme-sun-icon w-4.5 h-4.5 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364-6.364l-.707.707M6.343 17.657l-.707.707m12.728 0l-.707-.707M6.343 6.343l-.707-.707M12 8a4 4 0 100 8 4 4 0 000-8z" />
          </svg>
          <!-- Moon Icon (visible in light mode) -->
          <svg class="theme-moon-icon w-4.5 h-4.5 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
          </svg>
        </button>
        <span class="text-[10px] md:text-xs text-zinc-400 font-mono bg-zinc-900 border border-border-hairline rounded px-2.5 py-1">
          {version}
        </span>
      </div>
    </div>
  </header>

  <!-- Main Body Content -->
  <main class="flex-grow w-full max-w-7xl mx-auto px-4 py-8 flex flex-col gap-6">
    <!-- Hero / Title Header Section -->
    <div class="flex flex-col md:flex-row md:items-end justify-between gap-4 pt-2 pb-6 border-b border-border-hairline/60">
      <div class="flex flex-col gap-2">
        <h1 class="text-2xl md:text-3xl font-semibold tracking-tight text-zinc-50">
          {toolTitle}
        </h1>
        <p class="text-zinc-400 text-sm max-w-2xl leading-relaxed font-sans">
          {toolDescription}
        </p>
      </div>

      <!-- Pill Tab Switcher -->
      {tabs.length > 0 && (
        <div class="bg-panel border border-border-hairline rounded-full p-1 inline-flex items-center gap-1 self-start md:self-end">
          {tabs.map((tab) => (
            <a 
              href={tab.href} 
              class={`px-4 py-1.5 text-xs font-semibold rounded-full transition-all ${
                tab.active 
                  ? 'bg-zinc-800 text-zinc-50' 
                  : 'text-zinc-400 hover:text-zinc-50'
              }`}
            >
              {tab.label}
            </a>
          ))}
        </div>
      )}
    </div>

    <!-- Privacy Banner -->
    {showPrivacyBanner && (
      <div class="flex flex-wrap items-center justify-between gap-4 bg-panel border border-border-hairline rounded-lg px-4 py-3">
        <div class="flex items-center gap-2.5">
          <span class="flex h-2.5 w-2.5 relative">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-accent-emerald opacity-75"></span>
            <span class="relative inline-flex rounded-full h-2.5 w-2.5 bg-accent-emerald"></span>
          </span>
          <span class="text-xs md:text-sm text-zinc-300 font-medium font-sans">
            {privacyText}
          </span>
        </div>
        <div class="text-[10px] text-zinc-500 uppercase tracking-wider font-mono">
          100% Privacy Assurance
        </div>
      </div>
    )}

    <!-- Dynamic Slot for Tool Components -->
    <slot />

    <!-- Rich On-Page SEO Landing Page Content -->
    {((Astro.slots.has('seo-content') || faqs.length > 0)) && (
      <section class="mt-12 border-t border-border-hairline/60 pt-12 max-w-4xl mx-auto w-full">
        <div class="bg-panel border border-border-hairline rounded-xl p-6 md:p-10 shadow-sm flex flex-col gap-8">
          
          <!-- Section SEO articles -->
          <slot name="seo-content" />

          <!-- FAQ Grid -->
          {faqs.length > 0 && (
            <div>
              <h2 class="text-xl font-semibold text-zinc-50 tracking-tight mb-6 flex items-center gap-2">
                <span class="w-1.5 h-6 bg-accent-emerald rounded-full"></span>
                Frequently Asked Questions (FAQ)
              </h2>
              <div class="space-y-4">
                {faqs.map((faq) => (
                  <div class="p-4 bg-zinc-900/30 border border-border-hairline rounded-lg">
                    <h4 class="font-medium text-zinc-100 text-sm">{faq.question}</h4>
                    <p class="text-zinc-400 text-xs mt-2 leading-relaxed font-sans" set:html={faq.answer} />
                  </div>
                ))}
              </div>
            </div>
          )}

          <!-- Site Links inside the Panel -->
          <div class="border-t border-border-hairline/40 pt-6 mt-4 flex flex-col sm:flex-row items-center justify-between gap-4 text-xs text-zinc-500">
            <p class="text-zinc-400">
              Need more information about our local-only execution and terms?
            </p>
            <div class="flex items-center gap-3">
              <a href="/about" class="text-accent-emerald hover:underline font-mono">About Us</a>
              <span class="text-zinc-800">•</span>
              <a href="/privacy" class="text-accent-emerald hover:underline font-mono">Privacy Policy</a>
              <span class="text-zinc-800">•</span>
              <a href="/terms" class="text-accent-emerald hover:underline font-mono">Terms & Conditions</a>
              <span class="text-zinc-800">•</span>
              <a href="/contact" class="text-accent-emerald hover:underline font-mono">Contact Us</a>
            </div>
          </div>

        </div>
      </section>
    )}
  </main>

  <!-- Footer Section -->
  <footer class="w-full bg-canvas border-t border-border-hairline mt-auto">
    <div class="max-w-7xl mx-auto px-4 py-6 flex flex-col md:flex-row items-center justify-between gap-4 text-xs text-zinc-500">
      <div class="flex flex-col md:flex-row items-center gap-2 md:gap-4">
        <span>© 2026 useUtils.com</span>
        <span class="hidden md:inline text-zinc-800">•</span>
        <div class="flex items-center gap-3">
          <a href="/about" class="hover:text-zinc-350 transition-colors">About Us</a>
          <span class="text-zinc-800">•</span>
          <a href="/privacy" class="hover:text-zinc-350 transition-colors">Privacy Policy</a>
          <span class="text-zinc-800">•</span>
          <a href="/terms" class="hover:text-zinc-350 transition-colors">Terms & Conditions</a>
          <span class="text-zinc-800">•</span>
          <a href="/contact" class="hover:text-zinc-350 transition-colors">Contact Us</a>
        </div>
      </div>
      <div class="flex items-center gap-4">
        <span class="flex items-center gap-1.5 text-accent-emerald">
          <span class="w-1.5 h-1.5 rounded-full bg-accent-emerald"></span>
          Secure Client Sandbox
        </span>
      </div>
    </div>
  </footer>

  <!-- Schema-Ready JSON-LD for SoftwareApplication & FAQPage -->
  <script type="application/ld+json" is:inline set:html={JSON.stringify(jsonLd)} />
</Layout>
