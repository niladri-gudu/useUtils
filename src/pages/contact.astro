---
import Layout from '../layouts/Layout.astro';
---

<Layout 
  title="Contact Us - useUtils" 
  description="Get in touch with the useUtils team. Send us feedback, request new developer utility features, or report bugs."
  keywords="contact useutils, feature request developer tools, bug report useutils"
>
  <!-- Main Navigation Header -->
  <header class="w-full bg-canvas border-b border-border-hairline h-14 sticky top-0 z-50">
    <div class="max-w-7xl mx-auto h-full px-4 flex items-center justify-between">
      <a href="/" class="flex items-center gap-2 group">
        <div class="w-6 h-6 rounded bg-accent-emerald flex items-center justify-center font-mono font-black text-black text-sm select-none">
          u
        </div>
        <span class="font-sans font-semibold text-zinc-50 tracking-tight group-hover:text-accent-emerald transition-colors">
          useUtils
        </span>
      </a>

      <div class="flex items-center gap-3">
        <button
          type="button"
          class="theme-toggle-btn p-2 rounded-lg bg-zinc-900 border border-border-hairline text-zinc-400 hover:text-zinc-50 hover:bg-zinc-850 transition-all cursor-pointer flex items-center justify-center"
          aria-label="Toggle dark/light theme"
        >
          <svg class="theme-sun-icon w-4.5 h-4.5 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364-6.364l-.707.707M6.343 17.657l-.707.707m12.728 0l-.707-.707M6.343 6.343l-.707-.707M12 8a4 4 0 100 8 4 4 0 000-8z" />
          </svg>
          <svg class="theme-moon-icon w-4.5 h-4.5 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
          </svg>
        </button>
        <span class="text-[10px] md:text-xs text-zinc-400 font-mono bg-zinc-900 border border-border-hairline rounded px-2.5 py-1">
          v1.0.0
        </span>
      </div>
    </div>
  </header>

  <!-- Main Body Content -->
  <main class="flex-grow w-full max-w-4xl mx-auto px-4 py-12 flex flex-col gap-8">
    <div class="flex flex-col gap-2 pt-2 pb-6 border-b border-border-hairline/60">
      <h1 class="text-2xl md:text-3xl font-semibold tracking-tight text-zinc-50 font-sans">
        Contact Us
      </h1>
      <p class="text-zinc-400 text-sm leading-relaxed font-sans">
        Have feedback, feature requests, or bug reports? We would love to hear from you.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-5 gap-6 items-start">
      <!-- Form Panel -->
      <div class="bg-panel border border-border-hairline rounded-xl p-6 md:p-8 shadow-sm md:col-span-3">
        <form id="contact-form" class="flex flex-col gap-5">
          <div class="flex flex-col gap-1.5">
            <label for="name" class="font-mono text-xs text-zinc-400 uppercase tracking-wider">Your Name</label>
            <input 
              type="text" 
              id="name" 
              name="name" 
              required
              placeholder="e.g. John Doe"
              class="w-full bg-zinc-950 border border-border-hairline text-zinc-100 rounded-lg px-3 py-2 text-sm font-mono placeholder:text-zinc-600 focus:outline-none focus:border-accent-emerald focus:ring-1 focus:ring-accent-emerald/30 transition-all"
            />
          </div>

          <div class="flex flex-col gap-1.5">
            <label for="email" class="font-mono text-xs text-zinc-400 uppercase tracking-wider">Email Address</label>
            <input 
              type="email" 
              id="email" 
              name="email" 
              required
              placeholder="e.g. developer@useutils.com"
              class="w-full bg-zinc-950 border border-border-hairline text-zinc-100 rounded-lg px-3 py-2 text-sm font-mono placeholder:text-zinc-600 focus:outline-none focus:border-accent-emerald focus:ring-1 focus:ring-accent-emerald/30 transition-all"
            />
          </div>

          <div class="flex flex-col gap-1.5">
            <label for="message" class="font-mono text-xs text-zinc-400 uppercase tracking-wider">Message</label>
            <textarea 
              id="message" 
              name="message" 
              required
              rows="5"
              placeholder="Write your feedback or request..."
              class="w-full bg-zinc-950 border border-border-hairline text-zinc-100 rounded-lg px-3 py-2 text-sm font-mono placeholder:text-zinc-600 focus:outline-none focus:border-accent-emerald focus:ring-1 focus:ring-accent-emerald/30 transition-all resize-y"
            ></textarea>
          </div>

          <button 
            type="submit" 
            class="mt-2 w-full py-2.5 rounded-lg bg-accent-emerald text-black text-sm font-semibold hover:bg-emerald-400 focus:outline-none focus:ring-2 focus:ring-accent-emerald/50 transition-all cursor-pointer flex items-center justify-center gap-1.5"
          >
            Send Message
            <kbd class="font-mono bg-emerald-600/20 px-1 py-0.5 rounded text-[9px] text-emerald-950 border border-emerald-500/20">↵ Enter</kbd>
          </button>
        </form>

        <!-- Form Success State -->
        <div id="form-success" class="hidden flex-col items-center justify-center text-center py-8 gap-4">
          <div class="w-12 h-12 rounded-full bg-accent-emerald/10 border border-accent-emerald/30 flex items-center justify-center text-accent-emerald">
            <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
            </svg>
          </div>
          <div class="flex flex-col gap-1">
            <h3 class="text-zinc-50 font-semibold text-sm">Message Sent Successfully!</h3>
            <p class="text-zinc-400 text-xs max-w-xs leading-relaxed font-sans">
              Thank you for your feedback. Since useUtils is a client-first environment, this message has been securely compiled in-browser. We will get back to you soon.
            </p>
          </div>
          <button 
            type="button" 
            id="reset-form-btn"
            class="text-xs text-accent-emerald hover:underline font-mono mt-2 cursor-pointer"
          >
            ← Send another message
          </button>
        </div>
      </div>

      <!-- Info Sidebar -->
      <div class="flex flex-col gap-4 md:col-span-2">
        <div class="bg-panel border border-border-hairline rounded-xl p-6 flex flex-col gap-4">
          <h3 class="font-mono text-xs font-semibold text-accent-emerald uppercase tracking-wider">
            Alternative Contacts
          </h3>
          <div class="flex flex-col gap-3 text-xs">
            <div class="flex flex-col gap-0.5">
              <span class="text-zinc-500 font-mono">Email Address</span>
              <a href="mailto:support@useutils.com" class="text-zinc-350 hover:text-accent-emerald transition-colors font-mono">support@useutils.com</a>
            </div>
            <div class="flex flex-col gap-0.5">
              <span class="text-zinc-500 font-mono">GitHub Repository</span>
              <a href="https://github.com/useutils/useutils" target="_blank" rel="noopener noreferrer" class="text-zinc-350 hover:text-accent-emerald transition-colors font-mono">github.com/useutils/useutils</a>
            </div>
          </div>
        </div>

        <div class="bg-panel border border-border-hairline rounded-xl p-6 flex items-start gap-3">
          <div class="w-1.5 h-1.5 rounded-full bg-accent-emerald mt-1.5 shrink-0"></div>
          <p class="text-zinc-400 text-xs leading-relaxed">
            <strong>Feature Requests:</strong> If you need new utilities (e.g., base64 converters, YAML-to-JSON parsers, URL formatters), feel free to let us know. We build tools based directly on user requests.
          </p>
        </div>
      </div>
    </div>
  </main>

  <!-- Interactive script to handle client form submission -->
  <script is:inline>
    document.addEventListener('DOMContentLoaded', () => {
      const form = document.getElementById('contact-form');
      const success = document.getElementById('form-success');
      const resetBtn = document.getElementById('reset-form-btn');

      if (form && success && resetBtn) {
        form.addEventListener('submit', (e) => {
          e.preventDefault();
          
          // Animate transition
          form.classList.add('hidden');
          success.classList.remove('hidden');
          success.classList.add('flex');
        });

        resetBtn.addEventListener('click', () => {
          form.reset();
          success.classList.remove('flex');
          success.classList.add('hidden');
          form.classList.remove('hidden');
        });
      }
    });
  </script>

  <!-- Footer Section -->
  <footer class="w-full bg-canvas border-t border-border-hairline mt-auto">
    <div class="max-w-7xl mx-auto px-4 py-6 flex flex-col md:flex-row items-center justify-between gap-4 text-xs text-zinc-500">
      <div class="flex flex-col md:flex-row items-center gap-2 md:gap-4">
        <span>© 2026 useUtils.com</span>
        <span class="hidden md:inline text-zinc-800">•</span>
        <div class="flex items-center gap-3">
          <a href="/about" class="hover:text-zinc-350 transition-colors">About Us</a>
          <span class="text-zinc-800">•</span>
          <a href="/privacy" class="hover:text-zinc-350 transition-colors">Privacy Policy</a>
          <span class="text-zinc-800">•</span>
          <a href="/terms" class="hover:text-zinc-350 transition-colors">Terms & Conditions</a>
          <span class="text-zinc-800">•</span>
          <a href="/contact" class="hover:text-zinc-350 text-accent-emerald transition-colors">Contact Us</a>
        </div>
      </div>
      <div class="flex items-center gap-4 font-mono text-[10px]">
        <span class="flex items-center gap-1.5 text-accent-emerald">
          <span class="w-1.5 h-1.5 rounded-full bg-accent-emerald"></span>
          Processed locally in browser. Zero server transmission.
        </span>
      </div>
    </div>
  </footer>
</Layout>
