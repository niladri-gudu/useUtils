---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout 
  title="Contact Us - useUtils" 
  description="Get in touch with the useUtils team. Send us feedback, request new developer utility features, or report bugs."
  keywords="contact useutils, feature request developer tools, bug report useutils"
>
  <Header />

  <!-- Main Body Content -->
  <main class="flex-grow w-full max-w-2xl mx-auto px-4 py-16 flex flex-col gap-8 justify-center">
    <div class="flex flex-col gap-2 pt-2 pb-6 border-b border-border-hairline/60">
      <h1 class="text-3xl font-semibold tracking-tight text-zinc-50 font-sans">
        Contact & Connect
      </h1>
      <p class="text-zinc-400 text-sm leading-relaxed font-sans">
        Have feedback, feature requests, or want to collaborate? Reach out directly through any of the channels below.
      </p>
    </div>

    <div class="bg-panel border border-border-hairline rounded-xl p-8 shadow-sm flex flex-col gap-6">
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        
        <!-- Email -->
        <a 
          href="mailto:niladrigudu@gmail.com" 
          class="group flex flex-col gap-2 p-5 bg-zinc-950/40 hover:bg-zinc-900 border border-border-hairline hover:border-accent-emerald/40 rounded-xl transition-all duration-200"
        >
          <div class="flex items-center justify-between">
            <span class="font-mono text-xs text-zinc-500 uppercase tracking-wider">Email</span>
            <svg class="w-4 h-4 text-zinc-650 group-hover:text-accent-emerald transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
          </div>
          <span class="text-sm text-zinc-300 font-mono group-hover:text-zinc-100 transition-colors truncate">niladrigudu@gmail.com</span>
        </a>

        <!-- Twitter / X -->
        <a 
          href="https://x.com/dev_niladri" 
          target="_blank" 
          rel="noopener noreferrer" 
          class="group flex flex-col gap-2 p-5 bg-zinc-950/40 hover:bg-zinc-900 border border-border-hairline hover:border-accent-emerald/40 rounded-xl transition-all duration-200"
        >
          <div class="flex items-center justify-between">
            <span class="font-mono text-xs text-zinc-500 uppercase tracking-wider">Twitter / X</span>
            <svg class="w-4 h-4 text-zinc-650 group-hover:text-accent-emerald transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8" />
            </svg>
          </div>
          <span class="text-sm text-zinc-300 font-mono group-hover:text-zinc-100 transition-colors truncate">@dev_niladri</span>
        </a>

        <!-- LinkedIn -->
        <a 
          href="https://www.linkedin.com/in/niladribihari-mohanta/" 
          target="_blank" 
          rel="noopener noreferrer" 
          class="group flex flex-col gap-2 p-5 bg-zinc-950/40 hover:bg-zinc-900 border border-border-hairline hover:border-accent-emerald/40 rounded-xl transition-all duration-200"
        >
          <div class="flex items-center justify-between">
            <span class="font-mono text-xs text-zinc-500 uppercase tracking-wider">LinkedIn</span>
            <svg class="w-4 h-4 text-zinc-650 group-hover:text-accent-emerald transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 8a6 6 0 016 6v7h-4v-7a2 2 0 00-2-2 2 2 0 00-2 2v7h-4v-7a6 6 0 016-6zM2 9h4v12H2z" />
              <circle cx="4" cy="4" r="2" fill="currentColor" stroke="none" />
            </svg>
          </div>
          <span class="text-sm text-zinc-300 font-mono group-hover:text-zinc-100 transition-colors truncate">niladribihari-mohanta</span>
        </a>

        <!-- GitHub -->
        <a 
          href="https://github.com/niladri-gudu/useUtils" 
          target="_blank" 
          rel="noopener noreferrer" 
          class="group flex flex-col gap-2 p-5 bg-zinc-950/40 hover:bg-zinc-900 border border-border-hairline hover:border-accent-emerald/40 rounded-xl transition-all duration-200"
        >
          <div class="flex items-center justify-between">
            <span class="font-mono text-xs text-zinc-500 uppercase tracking-wider">GitHub</span>
            <svg class="w-4 h-4 text-zinc-650 group-hover:text-accent-emerald transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4" />
            </svg>
          </div>
          <span class="text-sm text-zinc-300 font-mono group-hover:text-zinc-100 transition-colors truncate">niladri-gudu/useUtils</span>
        </a>

      </div>

      <div class="flex items-start gap-3 bg-zinc-950/20 border border-border-hairline rounded-lg p-4">
        <div class="w-1.5 h-1.5 rounded-full bg-accent-emerald mt-1.5 shrink-0"></div>
        <p class="text-zinc-400 text-xs leading-relaxed font-sans">
          <strong>Feature Requests & Bug Reports:</strong> We build features based directly on developer feedback. If you have requests, suggestions, or bug reports regarding our Developer Tools, Playgrounds, Cheatsheets, Labs, or Config Builders, open a GitHub issue or DM us on X.
        </p>
      </div>
    </div>
  </main>

  <Footer />
</Layout>
