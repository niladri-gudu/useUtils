---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout 
  title="Terms & Conditions - useUtils" 
  description="Read our terms of service. useUtils is provided as-is, executing completely inside your browser sandbox for maximum privacy."
  keywords="terms of service, useutils terms, developer tools licensing"
>
  <Header />

  <!-- Main Body Content -->
  <main class="flex-grow w-full max-w-4xl mx-auto px-4 py-12 flex flex-col gap-10">
    <div class="flex flex-col gap-2 pt-2 pb-6 border-b border-border-hairline/60">
      <h1 class="text-3xl font-semibold tracking-tight text-zinc-50 font-sans">
        Terms & Conditions
      </h1>
      <p class="text-zinc-400 text-sm leading-relaxed font-sans">
        Last updated: June 10, 2026. Please read our guidelines and usage terms.
      </p>
    </div>

    <div class="bg-panel border border-border-hairline rounded-xl p-6 md:p-10 shadow-sm flex flex-col gap-8">
      
      <!-- Section 1 -->
      <div class="flex flex-col gap-2">
        <h2 class="text-base font-semibold text-zinc-50 tracking-tight flex items-center gap-2.5">
          <span class="w-1.5 h-4 bg-accent-emerald rounded-full"></span>
          1. Terms of Use
        </h2>
        <p class="text-zinc-400 text-xs md:text-sm leading-relaxed font-sans pl-4">
          By accessing and using <strong class="text-zinc-200">useUtils</strong>, you agree to comply with and be bound by these terms. This site is provided for educational and utility purposes to assist software developers in encoding, decoding, formatting, and analyzing structural payloads.
        </p>
      </div>

      <!-- Section 2 -->
      <div class="flex flex-col gap-2">
        <h2 class="text-base font-semibold text-zinc-50 tracking-tight flex items-center gap-2.5">
          <span class="w-1.5 h-4 bg-accent-emerald rounded-full"></span>
          2. Client-Side Execution & Security
        </h2>
        <p class="text-zinc-400 text-xs md:text-sm leading-relaxed font-sans pl-4">
          All utilities on this site run fully inside the client's browser sandbox using local JavaScript. You acknowledge that you are responsible for maintaining the security of your own local computer, operating system, and browser cache when processing sensitive keys, secrets, or certificates.
        </p>
      </div>

      <!-- Section 3 -->
      <div class="flex flex-col gap-2">
        <h2 class="text-base font-semibold text-zinc-50 tracking-tight flex items-center gap-2.5">
          <span class="w-1.5 h-4 bg-accent-emerald rounded-full"></span>
          3. Disclaimer of Warranty
        </h2>
        <p class="text-zinc-400 text-xs md:text-sm leading-relaxed font-sans pl-4 font-mono text-[11px] md:text-xs bg-zinc-900/40 p-4 border border-border-hairline rounded-lg uppercase">
          THE UTILITIES AND CONTENT ARE PROVIDED "AS IS", WITHOUT WARRANTY OF ANY KIND, EXPRESS OR IMPLIED, INCLUDING BUT NOT LIMITED TO THE WARRANTIES OF MERCHANTABILITY, FITNESS FOR A PARTICULAR PURPOSE, AND NONINFRINGEMENT. IN NO EVENT SHALL THE AUTHORS OR COPYRIGHT HOLDERS BE LIABLE FOR ANY CLAIM, DAMAGES, OR OTHER LIABILITY, WHETHER IN AN ACTION OF CONTRACT, TORT, OR OTHERWISE, ARISING FROM, OUT OF OR IN CONNECTION WITH THE UTILITIES OR THE USE OR OTHER DEALINGS IN THE UTILITIES.
        </p>
      </div>

      <!-- Section 4 -->
      <div class="flex flex-col gap-2">
        <h2 class="text-base font-semibold text-zinc-50 tracking-tight flex items-center gap-2.5">
          <span class="w-1.5 h-4 bg-accent-emerald rounded-full"></span>
          4. Open Source & Contributions
        </h2>
        <p class="text-zinc-400 text-xs md:text-sm leading-relaxed font-sans pl-4">
          This project is built using modern web standards. We encourage checking the source files in our repository to verify execution transparency and audit the local-first execution.
        </p>
      </div>

    </div>
  </main>

  <Footer />
</Layout>
