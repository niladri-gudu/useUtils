{
	"name": "useutils",
	"preview_urls": false,
	"main": "@astrojs/cloudflare/entrypoints/server",
	"compatibility_date": "2026-06-10",
	"compatibility_flags": [
		"nodejs_compat",
		"global_fetch_strictly_public"
	],
	"assets": {
		"binding": "ASSETS",
		"directory": "./dist"
	},
	"kv_namespaces": [
		{
			"binding": "SESSION",
			"id": "1e896f84c90b454690bf897848eb41f6"
		}
	],
	"observability": {
		"enabled": true
  }
}